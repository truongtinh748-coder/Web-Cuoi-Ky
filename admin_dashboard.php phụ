function e($value) {
    return htmlspecialchars((string)$value, ENT_QUOTES, 'UTF-8');
}

function fetchAllAssoc($conn, $sql) {
    $res = mysqli_query($conn, $sql);
    if (!$res) {
        die("SQL Error: " . mysqli_error($conn));
    }
    return mysqli_fetch_all($res, MYSQLI_ASSOC);
}

function fetchOneAssoc($conn, $sql) {
    $res = mysqli_query($conn, $sql);
    if (!$res) {
        die("SQL Error: " . mysqli_error($conn));
    }
    return mysqli_fetch_assoc($res);
}

if (isset($_GET['toggle_code'], $_GET['set_status'])) {
    $toggleCode = mysqli_real_escape_string($conn, $_GET['toggle_code']);
    $setStatus = mysqli_real_escape_string($conn, $_GET['set_status']);

    $query_toggle = "UPDATE subjects
                     SET status = '$setStatus'
                     WHERE subject_id = '$toggleCode'";

    if (!mysqli_query($conn, $query_toggle)) {
        die("LỖI HỆ THỐNG DATABASE: " . mysqli_error($conn));
    }

    if (isset($_GET['ajax']) && $_GET['ajax'] == 1) {
        header('Content-Type: application/json; charset=utf-8');
        echo json_encode([
            'success' => true,
            'new_status' => $setStatus,
            'subject' => $toggleCode
        ], JSON_UNESCAPED_UNICODE);
        exit();
    }

    header("Location: admin_dashboard.php?success_toggle=" . urlencode($toggleCode));
    exit();
}

