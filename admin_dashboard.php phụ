if (isset($_POST['edit_question'])) {
    $qid = (int)$_POST['question_index'];
    $subjectId = trim($_POST['subjectId']);
    $questionText = trim($_POST['question']);
    $a = trim($_POST['A']);
    $b = trim($_POST['B']);
    $c = trim($_POST['C']);
    $d = trim($_POST['D']);
    $correct = strtoupper(trim($_POST['correct']));
    $difficulty = trim($_POST['difficulty'] ?? 'easy');
    $status = trim($_POST['status'] ?? 'approved');

    $stmt = mysqli_prepare($conn, "UPDATE questions
        SET subject_id = ?, question_text = ?, option_a = ?, option_b = ?, option_c = ?, option_d = ?, correct_answer = ?, difficulty = ?, status = ?
        WHERE id = ?");

    mysqli_stmt_bind_param($stmt, "sssssssssi", $subjectId, $questionText, $a, $b, $c, $d, $correct, $difficulty, $status, $qid);
    mysqli_stmt_execute($stmt);
    mysqli_stmt_close($stmt);

    header("Location: admin_dashboard.php?success_edit=1");
    exit();
}

if (isset($_POST['add_user'])) {
    $username = trim($_POST['username']);
    $password = trim($_POST['password']);
    $fullname = trim($_POST['fullname']);
    $email = trim($_POST['email']);
    $role = trim($_POST['role']);

    if ($username !== '' && $password !== '') {
        $check = mysqli_prepare($conn, "SELECT id FROM users WHERE username = ?");
        mysqli_stmt_bind_param($check, "s", $username);
        mysqli_stmt_execute($check);
        mysqli_stmt_store_result($check);

        if (mysqli_stmt_num_rows($check) > 0) {
            mysqli_stmt_close($check);
            header("Location: admin_dashboard.php?error_add=exists");
            exit();
        }
        mysqli_stmt_close($check);

        $hashed = password_hash($password, PASSWORD_DEFAULT);

        $stmt = mysqli_prepare($conn, "INSERT INTO users (username, password, fullname, email, role) VALUES (?, ?, ?, ?, ?)");
        mysqli_stmt_bind_param($stmt, "sssss", $username, $hashed, $fullname, $email, $role);
        mysqli_stmt_execute($stmt);
        mysqli_stmt_close($stmt);

        header("Location: admin_dashboard.php?success_add=1");
        exit();
    }
}

