<script>
function openEditModal(index, data) {
    document.getElementById('modal_index').value = index;
    document.getElementById('modal_subject').value = data.subject_id || data.subjectId || '';
    document.getElementById('modal_exam_code').value = data.exam_code || data.examCode || '';
    document.getElementById('modal_question').value = data.question_text || data.question || '';
    document.getElementById('modal_a').value = data.option_a || data.A || '';
    document.getElementById('modal_b').value = data.option_b || data.B || '';
    document.getElementById('modal_c').value = data.option_c || data.C || '';
    document.getElementById('modal_d').value = data.option_d || data.D || '';
    document.getElementById('modal_correct').value = data.correct_answer || data.correct || 'A';
    document.getElementById('modal_difficulty').value = data.difficulty || 'easy';
    document.getElementById('modal_status').value = data.status || 'approved';
    document.getElementById('editModal').style.display = 'flex';
}
function closeEditModal() { document.getElementById('editModal').style.display = 'none'; }
function openAddUserModal() { document.getElementById('addUserModal').style.display = 'flex'; }
function closeAddUserModal() { document.getElementById('addUserModal').style.display = 'none'; }
function toggleChatPanel() {
    const panel = document.getElementById('chatPanel');
    panel.classList.toggle('open');
}
function confirmAction(event, targetUrl, titleText, detailText) {
    event.preventDefault();
    Swal.fire({
        title: titleText,
        text: detailText,
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#ef4444',
        cancelButtonColor: '#64748b',
        confirmButtonText: 'Đồng ý thực hiện',
        cancelButtonText: 'Hủy bỏ'
    }).then((result) => {
        if (result.isConfirmed) window.location.href = targetUrl;
    });
}
function kickUser(username) {
    Swal.fire({
        title: 'Hủy phiên học sinh?',
        text: 'Học sinh ' + username + ' sẽ bị ngắt phiên hiện tại.',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#ef4444',
        cancelButtonText: 'Hủy bỏ',
        confirmButtonText: 'Đồng ý'
    }).then((result) => {
        if (result.isConfirmed) {
            Swal.fire({
                icon: 'success',
                title: 'Thành công!',
                text: 'Đã hủy phiên của học sinh.',
                timer: 1800,
                showConfirmButton: false
            });
        }
    });
}
document.addEventListener('click', function(event) {
    const toggleBtn = event.target.closest('.btn-toggle-exam');
    if (!toggleBtn) return;

    event.preventDefault();
    const targetUrl = toggleBtn.getAttribute('href') + '&ajax=1';
    const subject = toggleBtn.getAttribute('data-subject');
    const row = toggleBtn.closest('tr');
    const statusCell = row.querySelector('td:nth-child(3)');
    const actionCell = row.querySelector('td:nth-child(4)');

    fetch(targetUrl)
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                if (data.new_status === 'open') {
                    statusCell.innerHTML = '<span class="role-badge status-open">🟢 Đang mở</span>';
                    actionCell.innerHTML = `<a href="admin_dashboard.php?toggle_code=${encodeURIComponent(subject)}&set_status=closed" class="btn-toggle-off btn-toggle-exam" data-subject="${subject}">🔒 Khóa đề</a>`;
                } else {
                    statusCell.innerHTML = '<span class="role-badge status-closed">🔴 Đang khóa</span>';
                    actionCell.innerHTML = `<a href="admin_dashboard.php?toggle_code=${encodeURIComponent(subject)}&set_status=open" class="btn-toggle-on btn-toggle-exam" data-subject="${subject}">🚀 Mở thi</a>`;
                }
                Swal.fire({
                    icon: 'success',
                    title: 'Đã cập nhật trạng thái đề ' + data.subject + '!',
                    toast: true,
                    position: 'top-end',
                    showConfirmButton: false,
                    timer: 2000,
                    timerProgressBar: true
                });
            }
        })
        .catch(() => {
            Swal.fire({ icon: 'error', title: 'Lỗi!', text: 'Không thể cập nhật trạng thái đề thi.' });
        });
});
</script>

